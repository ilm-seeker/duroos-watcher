{
  "name": "duroos-watcher",
  "private": true,
  "version": "0.1.0",
  "description": "Open-source local media harness for decentralized scholarly media distribution.",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://github.com/ilm-seeker/duroos-watcher/releases",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ilm-seeker/duroos-watcher.git"
  },
  "bugs": {
    "url": "https://github.com/ilm-seeker/duroos-watcher/issues"
  },
  "keywords": [
    "media-harness",
    "scholarly-media",
    "decentralized",
    "local-first",
    "offline-first",
    "tauri",
    "react",
    "typescript",
    "agpl",
    "signed-manifests",
    "education"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "media-tools:fetch": "node scripts/fetch-media-tools.mjs",
    "release:preflight": "node scripts/release-preflight.mjs",
    "release:check": "node scripts/release-check.mjs",
    "release:configure-signing": "node scripts/configure-github-release-signing.mjs",
    "release:audit-artifacts": "node scripts/audit-release-artifacts.mjs",
    "release:production-gate": "node scripts/production-release-gate.mjs",
    "tauri:build:app": "tauri build --bundles app --ci",
    "tauri:install:local": "npm run tauri:build:app && node scripts/install-local-macos-app.mjs",
    "tauri:build:full": "tauri build --ci",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.4",
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
