{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Duroos Watcher",
  "version": "0.1.0",
  "identifier": "io.duroos.watcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Duroos Watcher",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/library/**"]
      }
    }
  }
}
